# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Database
# Development: sqlite:///./lotto.db
# Production:  postgresql://user:password@host:5432/lotto_analytics
DATABASE_URL=sqlite:///./lotto.db

# Anthropic API — used by analytics/insights/ for AI explanations
ANTHROPIC_API_KEY=

# Environment
# development | production
APP_ENV=development

# Ingestion
# Source URL for Mega-Sena results (Caixa CEF)
MEGA_SENA_SOURCE_URL=
